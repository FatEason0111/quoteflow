NODE_ENV=development
APP_NAME=quoteflow-api
APP_VERSION=v0.0.1
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pricetool?schema=public
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:5500,http://localhost:5500
SESSION_COOKIE_NAME=pricetool_session
